{
  "name": "encryptic-movies",
  "version": "1.0.8",
  "description": "Encryptic Movies — desktop movies, TV, and anime",
  "author": {
    "name": "Joe",
    "email": "Longno242@users.noreply.github.com"
  },
  "license": "GPL-3.0",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "start": "vite build && electron .",
    "restart": "powershell -Command \"Get-Process electron -ErrorAction SilentlyContinue | Stop-Process -Force; exit 0\" && vite build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist": "cross-env ELECTRON_DIST=1 vite build && npm run dist:linux && npm run dist:win && npm run dist:mac",
    "dist:linux": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux deb AppImage pacman --publish never",
    "dist:deb": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux deb --publish never",
    "dist:arch": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux pacman --publish never",
    "dist:appimage": "cross-env ELECTRON_DIST=1 vite build && electron-builder --linux AppImage --publish never",
    "dist:win": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win --publish never",
    "dist:win-desktop": "cross-env ELECTRON_DIST=1 vite build && electron-builder --win portable --publish never && powershell -Command \"Copy-Item -Path 'dist/Encryptic Movies.exe' -Destination ([Environment]::GetFolderPath('Desktop') + '/Encryptic Movies.exe') -Force\"",
    "dist:mac": "cross-env ELECTRON_DIST=1 vite build && electron-builder --mac --publish never",
    "installer:preview": "electron installer/main.js",
    "installer:cache-posters": "node installer/cachePostersToDisk.js",
    "dist:win-setup": "node scripts/build-win-setup.js"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "ffmpeg-static": "^5.3.0",
    "keytar": "^7.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.encryptic.movies",
    "productName": "Encryptic Movies",
    "asar": true,
    "compression": "normal",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "!dist/mac/**",
      "!dist/mac-arm64/**",
      "!dist/win-unpacked/**",
      "!dist/linux-unpacked/**",
      "!dist/*.dmg",
      "!dist/*.exe",
      "!dist/*.deb",
      "!dist/*.AppImage",
      "!dist/*.blockmap",
      "!dist/*.yaml",
      "!dist/.icon-icns/**",
      "electron/**/*",
      "github.config.json",
      "package.json",
      "DOCUMENTATION.md",
      "tmdb-tutorial.md",
      "!**/*.map",
      "!**/*.md",
      "!**/*.ts",
      "!**/*.d.ts",
      "!**/node_modules/.cache/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,changelog.md,CHANGES,LICENCE,LICENSE}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples,benchmark,benchmarks}/**",
      "!**/node_modules/.bin/**",
      "!**/node_modules/*/*.d.ts",
      "!**/{.eslintrc,.babelrc,.editorconfig,.nycrc}",
      "!**/{jest.config,jest.config.js,jest.config.ts}",
      "!**/node_modules/*/docs/**",
      "!**/node_modules/vite/**",
      "!**/node_modules/@vitejs/**",
      "!**/node_modules/terser/**",
      "!**/node_modules/rollup/**",
      "!**/node_modules/esbuild/**",
      "!**/node_modules/@esbuild/**",
      "!**/node_modules/@rollup/**"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createStartMenuShortcut": true,
      "selectPerMachineByDefault": false,
      "license": "LICENSE",
      "uninstallDisplayName": "Uninstall Encryptic Movies",
      "installerSidebar": "public/installer-sidebar.bmp"
    },
    "win": {
      "icon": "public/encryptic-logo.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Encryptic Movies.${ext}"
    },
    "mac": {
      "icon": "public/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "public/icon.png"
    },
    "electronLanguages": [
      "en-US",
      "de"
    ],
    "asarUnpack": [
      "src/styles/fonts/**",
      "**/*.node",
      "node_modules/keytar/**",
      "node_modules/ffmpeg-static/**"
    ],
    "portable": {
      "artifactName": "Encryptic Movies.${ext}"
    }
  }
}
